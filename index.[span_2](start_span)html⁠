<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Basketball GM Sim</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-white min-h-screen">
<div class="max-w-6xl mx-auto p-3">

<h1 class="text-3xl font-bold mb-3">🏀 Basketball GM Simulator</h1>

<div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-4">
<button onclick="tab('team')" class="bg-blue-600 p-3 rounded">My Team</button>
<button onclick="tab('stand')" class="bg-slate-700 p-3 rounded">Standings</button>
<button onclick="tab('free')" class="bg-slate-700 p-3 rounded">Free Agency</button>
<button onclick="tab('game')" class="bg-slate-700 p-3 rounded">Next Game</button>
</div>

<div id="app"></div>

</div>

<script>
const names=[
"Dragons","Wolves","Kings","Storm",
"Falcons","Titans","Sharks","Bulls"
];

const first=[
"James","Mike","Alex","Chris","Tyler",
"Jordan","Dylan","Marcus","Kevin","Ryan"
];

let year=1;
let my=0;
let games=0;

function rand(a,b){
return Math.floor(Math.random()*(b-a+1))+a;
}

function player(){
let o=rand(65,88);
return{
name:first[rand(0,9)]+" "+String.fromCharCode(65+rand(0,25)),
age:rand(19,34),
ovr:o,
inside:rand(60,90),
outside:rand(60,90),
def:rand(60,90),
ath:rand(60,90),
pts:0
}
}

let teams=names.map((n,i)=>({
name:n,
wins:0,
loss:0,
players:Array.from({length:10},player)
}));

function power(t){
return t.players.reduce((a,p)=>a+p.ovr,0)/10;
}

function nav(){
document.querySelectorAll("button").forEach(b=>b.className="bg-slate-700 p-3 rounded");
}

function tab(x){
nav();
if(x==="team") renderTeam();
if(x==="stand") renderStand();
if(x==="free") renderFree();
if(x==="game") renderGame();
}

function renderTeam(){
let t=teams[my];

app.innerHTML=
`
<div class="bg-slate-900 rounded p-4">
<h2 class="text-xl font-bold mb-2">${t.name}</h2>
<p>Season ${year} | Record ${t.wins}-${t.loss}</p>

<button onclick="simSeason()" class="mt-3 bg-green-600 p-3 rounded">
Simulate Season
</button>

<div class="mt-3 space-y-2">
${t.players.map(p=>
`
<div class="bg-slate-800 p-2 rounded">
<b>${p.name}</b>
 OVR ${p.ovr}
 Age ${p.age}
<br>
Inside ${p.inside}
 Outside ${p.outside}
 Defense ${p.def}
 Athletic ${p.ath}
</div>
`).join("")}
</div>
</div>
`;
}

function renderStand(){
let s=[...teams].sort((a,b)=>
(b.wins-b.loss)-(a.wins-a.loss));

app.innerHTML=
`
<div class="bg-slate-900 p-4 rounded">
<h2 class="text-xl font-bold">
Standings
</h2>

${s.map((t,i)=>
`
<div class="p-2">
${i+1}. ${t.name}
 ${t.wins}-${t.loss}
 Power ${power(t).toFixed(1)}
</div>
`).join("")}

</div>
`;
}

function renderFree(){

let free=[];

teams.forEach((t,ti)=>{
t.players.forEach(p=>{
if(p.ovr>82)
free.push({...p,team:ti});
});
});

app.innerHTML=
`
<div class="bg-slate-900 p-4 rounded">
<h2 class="text-xl font-bold">
Free Agency
</h2>

${free.map(p=>
`
<div class="bg-slate-800 p-2 mt-2 rounded">
${p.name}
 OVR ${p.ovr}
 Age ${p.age}
<button onclick="sign(${p.team},'${p.name}')"
class="bg-blue-600 p-1 rounded">
Scout
</button>
</div>
`).join("")}

</div>
`;
}

function renderGame(){

let opp=rand(0,7);
while(opp===my)opp=rand(0,7);

app.innerHTML=
`
<div class="bg-slate-900 p-4 rounded">
<h2 class="text-xl">
Next Game
</h2>

${teams[my].name}
 vs
${teams[opp].name}

<br>

<button onclick="play(${opp})"
class="bg-green-600 p-3 rounded mt-3">
Play Game
</button>

</div>
`;
}

function play(o){

let a=power(teams[my]);
let b=power(teams[o]);

if(Math.random()*(a+b)<a){
teams[my].wins++;
teams[o].loss++;
alert("Win!");
}else{
teams[o].wins++;
teams[my].loss++;
alert("Loss");
}

renderStand();
}
function simSeason(){

teams.forEach(t=>{
t.wins=0;
t.loss=0;
});

for(let i=0;i<56;i++){
for(let a=0;a<8;a++){
let b=rand(0,7);
while(b===a)b=rand(0,7);

let pa=power(teams[a]);
let pb=power(teams[b]);

if(Math.random()*(pa+pb)<pa){
teams[a].wins++;
teams[b].loss++;
}else{
teams[b].wins++;
teams[a].loss++;
}
}
}

playoffs();

offseason();

year++;

alert("Season complete!");
renderTeam();
}


function playoffs(){

let order=[...teams].sort((a,b)=>
(b.wins-b.loss)-(a.wins-a.loss));

let champ=order[0];

for(let i=0;i<4;i++){
let p=order[i];

p.players.forEach(x=>{
if(Math.random()>.5)
x.ovr+=1;
});
}

alert("Champion: "+champ.name);
}


function offseason(){

teams.forEach(t=>{
t.players.forEach(p=>{

p.age++;

let change=0;

if(p.age<24)
change=rand(0,3);

if(p.age>30)
change=-rand(0,2);

p.ovr=Math.max(60,p.ovr+change);

p.inside+=change;
p.outside+=change;
p.def+=change;
p.ath+=change;

});
});

}


function sign(team,name){

alert("Scouted "+name+
". No salary system yet.");
}


renderTeam();

</script>
</body>
</html>
